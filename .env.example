# Shared local defaults (copy to .env — never commit .env)
APP_ENV=local
LOG_LEVEL=info

DATABASE_URL=postgres://lab:lab@localhost:5432/crypto_exchange_lab?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Per-service HTTP ports
ACCOUNT_SERVICE_HTTP_PORT=8081
ORDER_SERVICE_HTTP_PORT=8082
MATCHING_ENGINE_HTTP_PORT=8083

# Service discovery (order-service)
ACCOUNT_SERVICE_URL=http://localhost:8081
MATCHING_ENGINE_URL=http://localhost:8083

# CEX web (Next.js :3003)
NEXT_PUBLIC_ORDER_API_URL=http://localhost:8082
NEXT_PUBLIC_MATCHING_API_URL=http://localhost:8083
NEXT_PUBLIC_MATCHING_WS_URL=ws://localhost:8083/ws/v1/market
NEXT_PUBLIC_ACCOUNT_API_URL=http://localhost:8081

# Matching engine seed order books (default on; set false to disable)
# MATCHING_SEED_BOOKS=true

# OrderBook DEX (:3001) + API (:8084)
ORDERBOOK_DEX_HTTP_PORT=8084
NEXT_PUBLIC_ORDERBOOK_DEX_API_URL=http://localhost:8084

# AMM DEX on Sepolia (dex-web tab — fill after deploy)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://rpc.sepolia.org
# NEXT_PUBLIC_LAB_TOKEN=
# NEXT_PUBLIC_LAB_USD=
# NEXT_PUBLIC_AMM_FACTORY=
# NEXT_PUBLIC_AMM_ROUTER=
# NEXT_PUBLIC_AMM_PAIR=

# HyperDEX perpetuals (:3002)
HYPERLIQUID_ENGINE_HTTP_PORT=8085
RISK_ENGINE_HTTP_PORT=8086
LIQUIDATION_ENGINE_HTTP_PORT=8087
FUNDING_ENGINE_HTTP_PORT=8088
NEXT_PUBLIC_HYPERLIQUID_API_URL=http://localhost:8085
NEXT_PUBLIC_RISK_API_URL=http://localhost:8086
NEXT_PUBLIC_FUNDING_API_URL=http://localhost:8088
FUNDING_INTERVAL=5m
FUNDING_RATE=0.0001

# Sepolia / RPC (Phase 4+)
# SEPOLIA_RPC_URL=
# PRIVATE_KEY=never_commit_real_keys

# RPC gateway + indexer (Phase 5)
RPC_GATEWAY_HTTP_PORT=8089
INDEXER_HTTP_PORT=8090
NEXT_PUBLIC_RPC_GATEWAY_URL=http://localhost:8089
# INDEXER_AMM_PAIR=
# INDEXER_LAB_TOKEN=
# INDEXER_LAB_USD=
# INDEXER_AMM_ROUTER=
# INDEXER_POLL_INTERVAL=12s
# INDEXER_BATCH_SIZE=8

# Grafana (local docker — Phase 6)
# GF_SECURITY_ADMIN_PASSWORD=lab
# Prometheus: http://localhost:9090
# Grafana: http://localhost:3000
